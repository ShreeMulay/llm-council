# ============================================
# TKE Morning Intelligence - Environment Variables
# ============================================
# Copy to .env and fill in values:
#   cp .env.example .env
#
# Bun auto-loads .env files — no dotenv needed.
# For the Python content-engine, use: set -a && source .env && set +a
# ============================================

# ── GCP Project ──────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# ── Firestore ────────────────────────────────
# Use "(default)" for the default database, or a named database ID
FIRESTORE_DATABASE_ID=(default)

# ── Service URLs ─────────────────────────────
# Pipeline service port (Cloud Run sets PORT automatically)
PORT=8080

# Content Engine URL (local dev = localhost:8000, prod = Cloud Run URL)
CONTENT_ENGINE_URL=http://localhost:8000

# ── Google Chat Webhooks ─────────────────────
# Phase 1: Webhook URLs for each Chat space
# Phase 3: These become unused when Chat App is implemented
CHAT_WEBHOOK_MINDSET=https://chat.googleapis.com/v1/spaces/YOUR_SPACE/messages?key=YOUR_KEY&token=YOUR_TOKEN
CHAT_WEBHOOK_CELEBRATIONS=https://chat.googleapis.com/v1/spaces/YOUR_SPACE/messages?key=YOUR_KEY&token=YOUR_TOKEN
CHAT_WEBHOOK_ERRORS=https://chat.googleapis.com/v1/spaces/YOUR_SPACE/messages?key=YOUR_KEY&token=YOUR_TOKEN

# ── External APIs ────────────────────────────
# OpenWeatherMap (free tier: 1000 calls/day)
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key

# Exa Search (replaces Tavily + GNews)
EXA_API_KEY=your-exa-api-key

# ── Google Calendar IDs ──────────────────────
# Gusto PTO calendar (imported .ics)
CALENDAR_GUSTO_ID=aq1a9qjeb0qsfihob4lavttvcvthv82n@import.calendar.google.com

# Jackson office calendar
CALENDAR_JACKSON_ID=thekidneyexperts.com_09o575tcf895dooh15n42f9tmo@group.calendar.google.com

# Provider schedule calendar
CALENDAR_PROVIDER_ID=c_731d2d64a4858ea33eb0283b629581c17f7c1bfdbb2e665eb2c386bebbb14950@group.calendar.google.com

# ── Google Cloud Auth ────────────────────────
# For local development, set path to service account key JSON
# On Cloud Run, this is handled automatically via workload identity
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
