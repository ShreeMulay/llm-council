    "@tanstack/react-query": "^5.60.0",
    "@xyflow/react": "^12.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "lucide-react": "^0.562.0",
    "react": "^19.0.0",
