# TKE Knowledge Base Configuration
# Copy to .env and fill in your API keys

# Qdrant (local by default, set URL + API key for Qdrant Cloud)
TKE_KB_QDRANT_URL=http://localhost:6333
TKE_KB_QDRANT_API_KEY=
TKE_KB_QDRANT_COLLECTION=tke_knowledge_base

# Voyage AI (embeddings)
TKE_KB_VOYAGE_API_KEY=your-voyage-api-key-here
TKE_KB_VOYAGE_MODEL=voyage-4-large

# Google Gemini (chat LLM)
TKE_KB_GEMINI_API_KEY=your-gemini-api-key-here
TKE_KB_GEMINI_MODEL=gemini-3.1-pro-preview

# Chunking
TKE_KB_CHUNK_SIZE=600
TKE_KB_CHUNK_OVERLAP=75

# Retrieval
TKE_KB_SEARCH_TOP_K=10
TKE_KB_SCORE_THRESHOLD=0.65
TKE_KB_CONTEXT_TOP_K=5
