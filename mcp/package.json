{
  "name": "llm-council-mcp",
  "version": "1.0.0",
  "description": "MCP server for LLM Council - multi-model deliberation tool",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "llm-council-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "cd .. && uv run pytest tests/test_model_registry.py -q",
    "test:package": "node --test tests/package-startup.test.mjs",
    "prepack": "npm run build",
    "generate:models": "cd .. && uv run python -m backend.model_registry"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
