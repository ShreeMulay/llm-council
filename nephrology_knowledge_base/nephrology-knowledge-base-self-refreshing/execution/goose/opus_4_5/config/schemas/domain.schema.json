{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Domain Index Schema",
  "description": "Schema for domain _index.md structured output",
  "type": "object",
  "properties": {
    "frontmatter": {
      "type": "object",
      "description": "YAML frontmatter metadata",
      "properties": {
        "title": {
          "type": "string",
          "description": "Human-readable domain title"
        },
        "domain": {
          "type": "string",
          "description": "Domain identifier (e.g., 01-clinical)"
        },
        "status": {
          "type": "string",
          "enum": ["skeleton", "draft", "reviewed", "published"],
          "description": "Current status of the content"
        },
        "generated_by": {
          "type": "string",
          "description": "LLM model that generated this content"
        },
        "generated_at": {
          "type": "string",
          "description": "ISO 8601 timestamp of generation"
        },
        "pass": {
          "type": "integer",
          "description": "Pass number that created/modified this"
        }
      },
      "required": ["title", "domain", "status", "generated_by", "generated_at", "pass"],
      "additionalProperties": false
    },
    "description": {
      "type": "string",
      "description": "Brief description of the domain scope (1-3 sentences)"
    },
    "topics": {
      "type": "array",
      "description": "List of topics in this domain",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Topic name (used in wikilinks)"
          },
          "wikilink": {
            "type": "string",
            "description": "Wikilink format for this topic"
          },
          "description": {
            "type": "string",
            "description": "Brief description of topic scope"
          },
          "subtopics": {
            "type": "array",
            "description": "List of subtopics for future expansion",
            "items": {
              "type": "string"
            }
          },
          "priority": {
            "type": "string",
            "enum": ["high", "medium", "low"],
            "description": "Priority for content development"
          },
          "suggested_sources": {
            "type": "array",
            "description": "Suggested authoritative sources for this topic",
            "items": {
              "type": "string"
            }
          }
        },
        "required": ["name", "description", "priority"],
        "additionalProperties": false
      }
    },
    "cross_domain_links": {
      "type": "array",
      "description": "Topics in other domains that relate to this domain",
      "items": {
        "type": "string"
      }
    },
    "authoritative_sources": {
      "type": "array",
      "description": "Key authoritative sources for this entire domain",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Source name"
          },
          "type": {
            "type": "string",
            "enum": ["guideline", "regulation", "journal", "textbook", "website"],
            "description": "Type of source"
          },
          "organization": {
            "type": "string",
            "description": "Publishing organization"
          },
          "url": {
            "type": "string",
            "description": "URL if available"
          }
        },
        "required": ["name", "type"],
        "additionalProperties": false
      }
    }
  },
  "required": ["frontmatter", "description", "topics"],
  "additionalProperties": false
}
