!mcp/src/generated/model-registry.json

# Frontend (only its generated registry projection is needed in container)
frontend/*
!frontend/src/
frontend/src/*
!frontend/src/generated/
frontend/src/generated/*
!frontend/src/generated/model-registry.json

# Data (runtime-generated)
data/

